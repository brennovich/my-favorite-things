font-family = "Go Mono"
font-size = 15
font-thicken = true
font-thicken-strength = 64

background-blur = true
background-opacity = 1

adjust-cursor-thickness = 5

cursor-color = "#6768aa"
cursor-text = "#f6f4f0"
cursor-style = "block"

bell-features = "no-title,attention"

window-padding-x = 15
window-padding-y = 15
window-title-font-family = "go Mono"
window-width = 78
window-height = 40

resize-overlay = "never"

macos-titlebar-style = "tabs"
macos-icon = "glass"

theme = "dark:marques-de-itu-dark,light:marques-de-itu-light"
