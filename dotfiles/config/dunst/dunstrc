# vim:ft=cfg

[global]
  font = "Cantarell 9"
  markup = "strip"

  # The format of the message. Possible variables are:
  #   %a  appname
  #   %s  summary
  #   %b  body
  #   %i  iconname (including its path)
  #   %I  iconname (without its path)
  #   %p  progress value if set ([  0%] to [100%]) or nothing
  format = "<b>%s</b>: %b"
  alignment = center

  # The frequency with wich text that is longer than the notification
  # window allows bounces back and forth.
  # This option conflicts with 'word_wrap'.
  # Set to 0 to disable
  bounce_freq = 0

  geometry = "100%x10-0+0"

  shrink = no
  word_wrap = no
  transparency = 4
  monitor = 0

  # Display notification on focused monitor
  follow = mouse

  # Draw a line of 'separatpr_height' pixel height between two notifications.
  separator_height = 1
  separator_color = frame

  padding = 4
  horizontal_padding = 8

  frame_width = 0
  frame_color = "#464646"

[urgency_low]
  background = "#101010"
  foreground = "#e3e3e3"
  timeout = 10

[urgency_normal]
  background = "#252525"
  foreground = "#f7f7f7"
  timeout = 10

[urgency_critical]
  background = "#e3e3e3"
  foreground = "#252525"
  timeout = 20

[shortcuts]
  close = mod4+n
  history = mod4+ctrl+n
