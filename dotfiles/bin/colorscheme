#!/bin/sh

if defaults read -g AppleInterfaceStyle &> /dev/null; then
	NEXT_COLORSCHEME=marques-de-itu-dark
else
	NEXT_COLORSCHEME=marques-de-itu-light
fi

if [ ! -z "$COLORSCHEME" ]; then
	if [ "$COLORSCHEME" != "$NEXT_COLORSCHEME" ]; then
		echo "Switching colorscheme from $COLORSCHEME to $NEXT_COLORSCHEME"
		command reset
	fi
fi

unset COLORSCHEME SHELL_THEME
export COLORSCHEME=$NEXT_COLORSCHEME

if ! [ -z ${KITTY_INSTALLATION_DIR} ]; then
	kitty @ set-colors -a ~/.config/kitty/themes/${COLORSCHEME}.conf
fi

if [ "$TERM_PROGRAM" = "Apple_Terminal" ]; then
	variant=$(echo "${COLORSCHEME##*-}" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')
	defaults write com.apple.Terminal "Default Window Settings" -string "Marques de Itu $variant"
	defaults write com.apple.Terminal "Startup Window Settings" -string "Marques de Itu $variant"
fi

source ~/.vim/pack/plugins/start/marques-de-itu/shell/${COLORSCHEME}.sh

pkill -SIGUSR1 "vi$" > /dev/null
